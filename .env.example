APP_NAME=contacts-api
APP_ENV=development
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/contacts_db
API_V1_PREFIX=/api/v1
LOG_LEVEL=INFO

# JWT / Auth
JWT_SECRET_KEY=dev-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Email / SMTP (for development you can use MailHog/Mailpit on port 1025)
EMAIL_FROM=noreply@example.com
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=
EMAIL_VERIFICATION_TOKEN_EXPIRE_HOURS=48
PASSVORD_RESET_TOKEN_EXPIRE_MINUTES=30

# Mail server for development fastapi-mail (Mailtrap sandbox)
MAIL_SERVER=sandbox.smtp.mailtrap.io
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_PORT=2525
MAIL_FROM=noreply@example.com

# CORS (comma separated)
CORS_ALLOWED_ORIGINS=["http://127.0.0.1:3000","http://localhost:3000","http://127.0.0.1:8000"]

# Rate limiting
RATE_LIMIT_DEFAULT=10/minute
RATE_LIMIT_STORAGE_URL=

# Cloudinary
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Docker runtime
API_PORT=8000
DB_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=contacts_db
